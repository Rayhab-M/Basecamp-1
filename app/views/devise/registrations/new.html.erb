<br><br>
<body style="background: linear-gradient(45deg, rgb(205, 222, 253), rgb(100, 96, 96)); background-size: cover; background-attachment: fixed; color: white; height: 100vh;">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-4">
        <h2 class="text-center" style="font-size: 2rem; font-weight: bold; color: #333;">Sign Up</h2>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="form-group">
            <%= f.label :email, class: "form-label", style: "font-size: 0.75rem;" %><br />
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "Enter your email", style: "font-size: 0.75rem; padding: 0.4rem;" %>
          </div>

          <div class="form-group mt-3">
            <%= f.label :password, class: "form-label", style: "font-size: 0.75rem;" %>
            <% if @minimum_password_length %>
              <em style="font-size: 0.7rem;">(<%= @minimum_password_length %> characters minimum)</em>
            <% end %><br />
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Enter your password", style: "font-size: 0.75rem; padding: 0.4rem;" %>
          </div>

          <div class="form-group mt-3">
            <%= f.label :password_confirmation, class: "form-label", style: "font-size: 0.75rem;" %><br />
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "Confirm your password", style: "font-size: 0.75rem; padding: 0.4rem;" %>
          </div>

          <div class="actions text-center mt-4">
            <%= f.submit "Sign up", class: "btn btn-secondary btn-block", style: "width: 100%; font-size: 0.9rem; padding: 0.5rem;" %>
          </div>
        <% end %>

        <div class="mt-3 text-center">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</body>
