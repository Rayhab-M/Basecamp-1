<%= form_with(model: project, class: "needs-validation", novalidate: true) do |form| %>
  <!-- Error messages display -->
  <% if project.errors.any? %>
    <div class="alert alert-danger">
      <h4 class="alert-heading" style="font-size: 1.2rem;"><%= pluralize(project.errors.count, "error") %> prohibited this project from being saved:</h4>
      <ul>
        <% project.errors.full_messages.each do |error| %>
          <li style="font-size: 0.9rem;"><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3 mt-3">
    <!-- Project Name -->
    <% form.label :name, class: "form-label", style: "font-size: 0.9rem;" %>
    <%= form.text_field :name, class: "form-control form-control-sm", placeholder: "Enter your project name", style: "font-size: 0.8rem;", required: true %>
    <div class="invalid-feedback" style="font-size: 0.8rem;">
      Please enter a project name.
    </div>
  </div>

  <div class="mb-3">
    <!-- Project Description -->
    <% form.label :description, class: "form-label", style: "font-size: 0.9rem;" %>
    <%= form.text_area :description, class: "form-control form-control-sm", placeholder: "Enter project description", rows: 3, style: "font-size: 0.8rem;", required: true %>
    <div class="invalid-feedback" style="font-size: 0.8rem;">
      Please enter a project description.
    </div>
  </div>

  <div class="mb-3">
    <!-- User Assignment -->
    <%= form.label :user_ids, "Assign Users", class: "form-label", style: "font-size: 0.9rem;" %>
    <div class="d-flex flex-column">
      <%= form.collection_check_boxes :user_ids, User.where.not(id: current_user.id), :id, :email do |user_check_box| %>
        <div class="form-check">
          <%= user_check_box.check_box(class: "form-check-input") %>
          <label class="form-check-label" style="font-size: 0.8rem;">
            <%= user_check_box.text %>
          </label>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Submit Button -->
  <div class="mt-4 text-center">
    <%= form.submit "Save Project", class: "btn btn-primary btn-sm", style: "font-size: 0.8rem;" %>
  </div>
<% end %>
