<br><br>


<div class="p-4 rounded-lg shadow-sm m-auto text-dark" style="background-color: #f0f8ff; max-width: 600px;">
  <!-- Project Name -->
  <h4 class="mb-2 text-dark font-weight-bold text-center" style="font-size: 1.3rem;">Project Name</h4>
  <h3 class="text-secondary text-center" style="font-size: 2rem; font-weight: bold;"><%= @project.name %></h3>
  <hr class="my-3" />

  <!-- Project Description -->
  <h2 class="h5 text-dark text-center" style="font-size: 1.2rem;">Project Description</h2>
  <p class="lead text-center" style="font-size: 1rem;"> <%= @project.description %></p>

   <!-- Users Assigned to the Project -->
  <% assigned_users = @project.users.where.not(id: current_user.id) # Exclude the creator (current_user) %>
  <% if assigned_users.empty? %>
 
  <% else %>
    <h3 class="mt-4 text-center">Users Assigned to This Project</h3>
    <ul class="list-unstyled text-center">
      <% assigned_users.each do |user| %>
        <li class="my-2" style="font-size: 1rem;">
          <%= user.email %>
        </li>
      <% end %>
    </ul>
  <% end %>


  <!-- Buttons for Edit, Back, and Delete -->
<% if @project.users.include?(current_user) || current_user.admin? %>
  <div class="mt-4 d-flex justify-content-center gap-3">
    <%= link_to 'Edit', edit_project_path(@project), class: "btn btn-outline-dark btn-sm" %> 
    <%= link_to 'Back', projects_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= link_to 'Delete', @project, data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }, class: "btn btn-danger btn-sm" %>
  </div>
<% end %>
</div>
